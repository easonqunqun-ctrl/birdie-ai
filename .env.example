# =====================================================
# 「小鸟 AI」环境变量模板
# 使用：cp .env.example .env.local 然后填入真实值
# =====================================================

# ==================== 应用 ====================
APP_ENV=local                          # local / dev / staging / prod（prod 启用启动门禁，不符则进程退出；紧急排障：SKIP_PRODUCTION_GUARD=1）
# SKIP_PRODUCTION_GUARD=               # prod 特例：1/true 跳过生产门禁，仅救火切勿常开
APP_DEBUG=true
APP_NAME=xiaoniao-ai
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_LOG_LEVEL=INFO

# ==================== Docker Compose 构建（只参与 `compose build` 的变量替换） ====================
# 国内链路访问 files.pythonhosted.org / PyPI 易超时：`make up --build` 前在 `.env.local` 取消注释其一
# UV_PYPI_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple

# ==================== 后端服务 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:10086
# C 端/小程序可见的 Backend 对外基址（含 scheme/host/port，不含 /v1）。生产须 https，
#   并与 MINIO_PUBLIC 回退推导、静态资源代理等一致。
API_PUBLIC_BASE_URL=http://localhost:8000

# ==================== JWT ====================
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xiaoniao
POSTGRES_PASSWORD=xiaoniao_dev_password
POSTGRES_DB=xiaoniao
DATABASE_URL=postgresql+asyncpg://xiaoniao:xiaoniao_dev_password@postgres:5432/xiaoniao
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ==================== 对象存储（本地用 MinIO 模拟 COS） ====================
STORAGE_PROVIDER=minio                 # minio / cos
MINIO_ENDPOINT=http://minio:9000
# 客户端直传（wx.uploadFile）可见的地址。本地开发保持 localhost；
# staging/prod 若为默认 localhost 占位，后端会自动改用 `{API_PUBLIC_BASE_URL}/minio`
#（须 nginx 在同主机挂载 MinIO）；否则在此显式写 https://api.example.com/minio。
# 【禁止】云上仍填 cloudflared/ngrok 等穿透域名——小程序无法在公众平台登记 uploadFile。
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xiaoniao-videos
MINIO_REGION=us-east-1

# 腾讯云 COS（`STORAGE_PROVIDER=cos` 时，后端用 S3 兼容直传；需控制台配置 CORS/桶策略）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=                             # 形如 yourbucket-1250000000
# COS_PUBLIC_BASE=                      # 可选：自定义域/CDN 根 URL（须与控制台 uploadFile 合法域名同源）

# ==================== 微信小程序 ====================
WECHAT_MINIPROGRAM_APPID=wx_placeholder_appid
WECHAT_MINIPROGRAM_SECRET=placeholder_secret
WECHAT_MOCK_LOGIN=true                 # 本地开发开启 mock 登录，绕过真实 wx.login；CVM/体验版/正式必须 false

# ==================== 微信开放平台（App 端） ====================
WECHAT_OPEN_APPID=wx_open_placeholder
WECHAT_OPEN_SECRET=placeholder_secret

# ==================== 微信支付（正式版：WECHAT_PAY_MOCK_MODE=false 并填全下列项） ====================
WECHAT_PAY_MOCK_MODE=true
WECHAT_PAY_MCH_ID=
# APIv3 密钥 32 位（与 WECHAT_PAY_API_KEY 二选一，优先 API_V3_KEY）
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_API_KEY=
# 商户 API 私钥：二选一 —— (1) 容器内可读路径（推荐与 docker-compose.wechat-pay-key.yml 挂载）
#   WECHAT_PAY_CERT_PATH=/secrets/apiclient_key.pem
# (2) 或整段 PEM 放进 WECHAT_PAY_PRIVATE_KEY_PEM=（换行写成 \n，适合 Secret 注入）
WECHAT_PAY_CERT_PATH=
# WECHAT_PAY_PRIVATE_KEY_PEM=
# 商户平台「API 证书」序列号（HTTP Authorization serial_no；非 apiclient_cert.pem 的 MD5）
WECHAT_PAY_MCH_SERIAL=
# 须公网 HTTPS；须与 nginx 反代路径一致（示例为同域 API）
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/v1/payments/wechat/notify
# 退款结果 notify；留空则自动将上一行路径中的 wechat/notify → wechat/refund-notify
WECHAT_PAY_REFUND_NOTIFY_URL=
# 支付成功后该小时内允许自助全额退款（0=关闭时间窗，仅用于测试）
PAYMENT_SELF_REFUND_WINDOW_HOURS=24

# 订单：待支付超过该分钟数 → Celery `xiaoniao.expire_stale_pending_orders` 置为 cancelled（需 beat/cron；见 docs/02 §6.6）
PAYMENT_PENDING_ORDER_EXPIRE_MINUTES=120

# ==================== 苹果内购 ====================
APPLE_BUNDLE_ID=com.xiaoniaoai.app
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_URL=https://sandbox.itunes.apple.com/verifyReceipt

# ==================== LLM ====================
LLM_PROVIDER=deepseek                  # deepseek / qwen / glm / openai
LLM_API_KEY=sk-placeholder
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=120                   # SSE 相邻 chunk 最大空闲间隔；首轮排队慢的模型可调大
LLM_HTTP_MAX_RETRIES=2                     # 429/5xx/网络抖动时整流重试（不含已输出的生成片段）
LLM_HTTP_RETRY_BACKOFF_BASE=0.75           # 重试间隔底数秒：0.75×2^attempt
SSE_IDLE_PING_SECONDS=22                   # 对话 SSE 在无 LLM 增量时周期性下发注释帧，缓解小程序/网关长空闲误判
# SSE_FRAME_THROTTLE_MS=15                  # （可选）每帧后发 ms 延迟；单测可调 0

# ==================== AI Engine ====================
AI_ENGINE_URL=http://ai_engine:9000
AI_ENGINE_TIMEOUT=60                    # W6-T4：从 120 降到 60；docs/14 §四
AI_ENGINE_MOCK_MODE=false               # W6-T4：默认走真实 MediaPipe 引擎；本地调试若想跳过模型推理改成 true

# ==================== 业务规则 / 配额 ====================
# W8-T3：测试期配额放宽
#   strict     - 默认/生产，按 FREE_USER_MONTHLY_ANALYSES (3) / FREE_USER_DAILY_CHATS (5) 严格扣减
#   unlimited  - W8 内测专用，免费用户也享受无限配额（避免内测团队被次数卡死）
# 切换不影响付费会员（会员本来就 -1）
QUOTA_MODE=strict

# ==================== 客户端 ====================
TARO_APP_API_BASE_URL=http://localhost:8000/v1
TARO_APP_ENV=local
# W10 RN：`pnpm dev:rn` / 真机构建需填开放平台「移动应用」AppID，与后端 WECHAT_OPEN_APPID 一致
TARO_APP_WECHAT_OPEN_APPID=
# W7-T2：支付 mock 开关；W8 接真实商户号后设为 false
TARO_APP_PAYMENT_MOCK=true
# W8-T3：客户端付费 UI 总开关；内测期（W8）= false，正式上线（W9）= true
TARO_APP_PAYMENT_ENABLED=false
