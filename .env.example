# =====================================================
# 「小鸟 AI」环境变量模板
# 使用：cp .env.example .env.local 然后填入真实值
# =====================================================

# ==================== 应用 ====================
APP_ENV=local                          # local / dev / staging / prod
APP_DEBUG=true
APP_NAME=xiaoniao-ai
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_LOG_LEVEL=INFO

# ==================== 后端服务 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:10086

# ==================== JWT ====================
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# ==================== PostgreSQL ====================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xiaoniao
POSTGRES_PASSWORD=xiaoniao_dev_password
POSTGRES_DB=xiaoniao
DATABASE_URL=postgresql+asyncpg://xiaoniao:xiaoniao_dev_password@postgres:5432/xiaoniao
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ==================== 对象存储（本地用 MinIO 模拟 COS） ====================
STORAGE_PROVIDER=minio                 # minio / cos
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xiaoniao-videos
MINIO_REGION=us-east-1

# 腾讯云 COS（生产环境）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=

# ==================== 微信小程序 ====================
WECHAT_MINIPROGRAM_APPID=wx_placeholder_appid
WECHAT_MINIPROGRAM_SECRET=placeholder_secret
WECHAT_MOCK_LOGIN=true                 # 本地开发开启 mock 登录，绕过真实 wx.login

# ==================== 微信开放平台（App 端） ====================
WECHAT_OPEN_APPID=wx_open_placeholder
WECHAT_OPEN_SECRET=placeholder_secret

# ==================== 微信支付 ====================
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=https://api.xiaoniaoai.com/v1/payments/wechat-notify

# ==================== 苹果内购 ====================
APPLE_BUNDLE_ID=com.xiaoniaoai.app
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_URL=https://sandbox.itunes.apple.com/verifyReceipt

# ==================== LLM ====================
LLM_PROVIDER=deepseek                  # deepseek / qwen / glm / openai
LLM_API_KEY=sk-placeholder
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ==================== AI Engine ====================
AI_ENGINE_URL=http://ai_engine:9000
AI_ENGINE_TIMEOUT=120
AI_ENGINE_MOCK_MODE=true               # true=返回 mock 分析结果（无需真实模型）

# ==================== 客户端 ====================
TARO_APP_API_BASE_URL=http://localhost:8000/v1
TARO_APP_ENV=local
