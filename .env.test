# =====================================================
# W8-T3：测试环境（CVM 单机）后端环境变量模板
# =====================================================
# 部署流程：
#   1. scp 本文件到部署目录下的 `.env.local`（与 compose 在同一目录；
#      若在 `/home/ubuntu/lingniao-golf` 运维，就在那里放 `.env.local`）
#   2. **禁止**再从仓库拷贝带尖括号的 `<...>`：历史上易被整段粘贴进运行时，导致 Postgres/Redis/MinIO「密码就是占位符字面量」。
#      密钥请用：`python3 -c "import secrets; print(secrets.token_urlsafe(48))"` 逐项替换。
#   3. `docker compose -f docker-compose.yml -f docker-compose.test.yml --env-file .env.local up -d --build`
# 与 `.env.example`（开发模板）的关键区别：
#   - APP_ENV=staging / WECHAT_MOCK_LOGIN=false / QUOTA_MODE=unlimited
#   - 云上须把 API_PUBLIC_BASE_URL / MINIO_PUBLIC_ENDPOINT / BACKEND_CORS_ORIGINS / 微信小程序凭证换成真值
#   - Redis：单机内网常见无口令；云上若设了口令，务必同时改 REDIS_URL 与本文件 REDIS_PASSWORD
# =====================================================

# ==================== 应用 ====================
APP_ENV=staging
APP_DEBUG=false
APP_NAME=xiaoniao-ai
# 生产前务必换成 openssl 随机串（不要使用 change-me-* 字面量）
APP_SECRET_KEY=w8-staging-token-urlsafe-run-openssl-48-before-prod-xxxx
APP_LOG_LEVEL=INFO

# ==================== 后端服务 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2
# 与网关对外 HTTPS 同源（不带 /v1）；用于推导图片代理同源、必要时回落 MinIO 公网前缀
API_PUBLIC_BASE_URL=https://test.birdieai.example.com
# 小程序 / 开发者工具预览来源；须覆盖实际请求的 Origin（可逗号多条）
BACKEND_CORS_ORIGINS=https://test.birdieai.example.com,https://servicewechat.com

# ==================== JWT ====================
JWT_SECRET_KEY=w8-staging-token-urlsafe-run-openssl-48-before-prod-yyyy
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# ==================== PostgreSQL ====================
# 须与 DATABASE_URL 中密码段落一致（修改只改两处同一字符串）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xiaoniao
POSTGRES_PASSWORD=w8_single_node_postgres_rotate_before_prod
POSTGRES_DB=xiaoniao
DATABASE_URL=postgresql+asyncpg://xiaoniao:w8_single_node_postgres_rotate_before_prod@postgres:5432/xiaoniao
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
# 单机内测常见留空（须与镜像内 Redis 一致；云上若有口令要写进 REDIS_URL）
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ==================== 对象存储 ====================
# W8 测试期沿用 MinIO（单机部署），W9 才迁 COS
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
# 必须与 MinIO ROOT 凭证一致（勿填与 docker-compose 镜像初始化不一致的假 AK）
MINIO_PUBLIC_ENDPOINT=https://test.birdieai.example.com/minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xiaoniao-videos-test
MINIO_REGION=us-east-1

# ==================== 微信小程序 ====================
# 线上测试 CVM（W8-T4）：须 false，走真实 wx.login。仅本地不配 AppSecret、不接微信时用 true。
WECHAT_MINIPROGRAM_APPID=
WECHAT_MINIPROGRAM_SECRET=
WECHAT_MOCK_LOGIN=false

# ==================== 微信支付 ====================
# W8 不开支付，全部走 mock；W9 接商户号后切 false
WECHAT_PAY_MOCK_MODE=true
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=

# ==================== LLM ====================
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ==================== AI Engine ====================
AI_ENGINE_URL=http://ai_engine:9000
AI_ENGINE_TIMEOUT=60
AI_ENGINE_MOCK_MODE=false

# ==================== 业务规则 / 配额 ====================
QUOTA_MODE=unlimited

# ==================== 客户端（仅作引用） ====================
# 客户端实际值在 client/.env.test 或 client/.env.test.local 中维护，这里只列出对照：
# TARO_APP_API_BASE_URL=https://test.birdieai.example.com/v1
# TARO_APP_ENV=test
# TARO_APP_PAYMENT_ENABLED=false
# TARO_APP_PAYMENT_MOCK=true
