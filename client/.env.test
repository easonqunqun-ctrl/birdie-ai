# W8-T2：测试环境客户端变量
# ─────────────────────────────────────────────────────────────
# Taro CLI 以 `taro build --type weapp --mode test`（package.json
# 的 `build:weapp:test` 脚本）启动时自动加载本文件；所有 `TARO_APP_*`
# 前缀变量会经 `config/index.ts::defineConstants` 注入到客户端代码。
#
# 本文件入仓，只放**非敏感**的环境默认值；真实 CVM IP / 域名由部署者
# 在本机 `.env.test.local` 覆盖（`.env.*.local` 自动 gitignore）。
# ─────────────────────────────────────────────────────────────

# 后端入口（测试环境单机 CVM + 自签 HTTPS；详见 W8-T4 的 runbook）
# 占位值必须被部署者替换：否则预览会出现 WAServiceMainContext Error: timeout。
# 推荐在本目录新建 `.env.test.local`（不入库）一行覆盖，例如：
#   TARO_APP_API_BASE_URL=https://api.birdieai.cn/v1
# 可复制模板：`env.test.local.sample`
TARO_APP_API_BASE_URL=https://test.example.com/v1

# 环境标识（驱动顶栏 test badge、日志前缀等；正式上线 = production）
TARO_APP_ENV=test

# 支付：W8 内测期后端走 mock 路径，前端 UI 完全不露出付费入口
TARO_APP_PAYMENT_MOCK=true
TARO_APP_PAYMENT_ENABLED=false

TARO_APP_PHASE2_PROFILE_V2_ENABLED=false
TARO_APP_PHASE2_COURSES_ENABLED=false
TARO_APP_PHASE2_PROS_ENABLED=false
TARO_APP_PHASE2_MEETUP_ENABLED=false
