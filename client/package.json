{
  "name": "xiaoniao-client",
  "version": "0.1.0",
  "private": true,
  "description": "小鸟 AI 客户端 - Taro 3（微信小程序 + React Native 双端）",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:rn": "taro build --type rn",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:rn": "taro build --type rn --watch",
    "dev:rn:ios": "cd rn-shell && npx react-native run-ios",
    "dev:rn:android": "cd rn-shell && npx react-native run-android",
    "lint": "eslint --ext .js,.ts,.tsx src/",
    "type-check": "tsc --noEmit"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "3.6.32",
    "@tarojs/helper": "3.6.32",
    "@tarojs/plugin-framework-react": "3.6.32",
    "@tarojs/plugin-platform-weapp": "3.6.32",
    "@tarojs/react": "3.6.32",
    "@tarojs/runtime": "3.6.32",
    "@tarojs/shared": "3.6.32",
    "@tarojs/taro": "3.6.32",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zustand": "^4.5.0"
  },
  "pnpm": {
    "comment": "Taro 3.6.32 内置的 ProgressPlugin 用了老 schema，不兼容 webpack 5.90+；钉回 5.88.x。",
    "overrides": {
      "webpack": "5.88.2"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "3.6.32",
    "@tarojs/webpack5-runner": "3.6.32",
    "@types/react": "^18.2.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "babel-preset-taro": "3.6.32",
    "eslint": "^8.57.0",
    "eslint-config-taro": "3.6.32",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.35",
    "react-refresh": "^0.14.0",
    "stylelint": "^16.2.0",
    "stylelint-config-taro-rn": "3.6.32",
    "typescript": "^5.3.0"
  }
}
