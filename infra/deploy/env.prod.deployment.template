WECHAT_MINIPROGRAM_SECRET=REPLACE_WX_SECRET
WECHAT_MOCK_LOGIN=false

WECHAT_OPEN_APPID=
WECHAT_OPEN_SECRET=

# ---------- 微信支付 V3（JSAPI）— 取值来自「pay.weixin.qq.com」商户平台，勿臆造 ----------
# 接真付：WECHAT_PAY_MOCK_MODE=false；留 true 则后端走 mock（与公众平台无资金往来）。
WECHAT_PAY_MOCK_MODE=true
# 商户号「账户中心」顶部所见 10 位数字
WECHAT_PAY_MCH_ID=
# API 安全 → 设置 APIv3 密钥：须正好 32 字符（可与 WECHAT_PAY_API_KEY 二选一）
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_API_KEY=
# 二选一载入商户 API 私钥（apiclient_key.pem， PKCS#8）：
# A) WECHAT_PAY_CERT_PATH=/容器内可读路径.pem（Compose 常见做法：挂载只读密钥卷到该路径）
# B) WECHAT_PAY_PRIVATE_KEY_PEM=\"-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----\"（多行；或挂载文件走 CERT_PATH）
WECHAT_PAY_CERT_PATH=
WECHAT_PAY_PRIVATE_KEY_PEM=
# 商户 API 证书 → 序列号（serial_no）；不是平台证书
WECHAT_PAY_MCH_SERIAL=
# HTTPS 公网直达本服务；须在商户平台「产品中心」等与小程序 AppID / 域名配置一致以便验签投递
WECHAT_PAY_NOTIFY_URL=https://api.birdieai.cn/v1/payments/wechat/notify
# 退款结果异步通知；留空则自动将路径 wechat/notify → wechat/refund-notify
WECHAT_PAY_REFUND_NOTIFY_URL=
# 支付成功后该小时内允许自助全额退款（小时；0 关闭窗仅测试）
PAYMENT_SELF_REFUND_WINDOW_HOURS=24

APPLE_BUNDLE_ID=com.xiaoniaoai.app
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_URL=https://sandbox.itunes.apple.com/verifyReceipt

LLM_PROVIDER=deepseek
LLM_API_KEY=REPLACE_LLM_KEY
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

AI_ENGINE_URL=http://ai_engine:9000
AI_ENGINE_TIMEOUT=60
AI_ENGINE_MOCK_MODE=false

QUOTA_MODE=unlimited

COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=
